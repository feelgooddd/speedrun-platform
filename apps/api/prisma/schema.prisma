generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  username        String   @unique
  display_name    String?
  email           String?  @unique
  password_hash   String?
  avatar_url      String?
  country         String?
  twitch          String?
  role            String   @default("user")
  is_placeholder  Boolean  @default(false)
  speedrun_com_id String?  @unique
  created_at      DateTime @default(now())

  runs            Run[]
  run_runners     RunRunner[]
  moderated_games GameModerator[]
  submitted_runs  Run[]   @relation("RunSubmitter")
}

model Game {
  id                  String    @id @default(cuid())
  slug                String    @unique
  name                String
  created_at          DateTime  @default(now())
  default_platform_id String?
  deleted_at          DateTime?

  platforms  Platform[]
  moderators GameModerator[]
}

model Platform {
  id            String    @id @default(cuid())
  game_id       String
  name          String
  slug          String
  timing_method String    @default("realtime")
  deleted_at    DateTime?

  game            Game             @relation(fields: [game_id], references: [id])
  runs            Run[]
  categories      Category[]
  platformSystems PlatformSystem[]

  levels     Level[]

}

model Category {
  id          String    @id @default(cuid())
  platform_id String
  name        String
  slug        String
  deleted_at  DateTime?

  order       Int       @default(0)


  platform      Platform      @relation(fields: [platform_id], references: [id])
  runs          Run[]
  subcategories Subcategory[]
  variables     Variable[]
}

// Kept for simple single-dimension games (e.g. Console/Emu, ACE/No ACE)
model Subcategory {
  id          String    @id @default(cuid())
  category_id String
  name        String
  slug        String
  deleted_at  DateTime?

  order       Int       @default(0)


  category Category @relation(fields: [category_id], references: [id])
  runs     Run[]
}

// For multi-dimensional variable systems (e.g. Players + Cut, Version)
model Variable {
  id                String  @id @default(cuid())
  category_id       String?
  level_category_id String?
  name              String
  slug              String
  is_subcategory    Boolean @default(true)

  category       Category?      @relation(fields: [category_id], references: [id])
  level_category LevelCategory? @relation(fields: [level_category_id], references: [id])
  values         VariableValue[]
}

model VariableValue {
  id               String  @id @default(cuid())
  variable_id      String
  name             String
  slug             String
  is_coop          Boolean @default(false)
  required_players Int?

  variable Variable         @relation(fields: [variable_id], references: [id])
  runs     RunVariableValue[]
}

model Run {
  id                String    @id @default(cuid())
  user_id           String
  category_id       String?
  level_category_id String?
  platform_id       String
  subcategory_id    String?
  is_coop           Boolean   @default(false)
  realtime_ms       Int?
  gametime_ms       Int?
  comment           String?
  video_url         String?
  verified          Boolean   @default(false)
  rejected          Boolean   @default(false)
  reject_reason     String?
  submitted_at      DateTime  @default(now())
  verified_at       DateTime?
  speedrun_com_id   String?   @unique
  system_id         String?
  submitted_by_id   String?

  user            User               @relation(fields: [user_id], references: [id])
  submitted_by    User?              @relation("RunSubmitter", fields: [submitted_by_id], references: [id])
  category        Category?          @relation(fields: [category_id], references: [id])
  level_category  LevelCategory?     @relation(fields: [level_category_id], references: [id])
  platform        Platform           @relation(fields: [platform_id], references: [id])
  subcategory     Subcategory?       @relation(fields: [subcategory_id], references: [id])
  system          System?            @relation(fields: [system_id], references: [id])
  variable_values RunVariableValue[]
  runners         RunRunner[]
}

// Join table: which variable values apply to this run
model RunVariableValue {
  run_id             String
  variable_value_id  String

  run            Run           @relation(fields: [run_id], references: [id])
  variable_value VariableValue @relation(fields: [variable_value_id], references: [id])

  @@id([run_id, variable_value_id])
}

// For coop runs: all runners on a run
model RunRunner {
  run_id  String
  user_id String

  run  Run  @relation(fields: [run_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@id([run_id, user_id])
}

model GameModerator {
  user_id String
  game_id String
  role    String @default("moderator")

  user User @relation(fields: [user_id], references: [id])
  game Game @relation(fields: [game_id], references: [id])

  @@id([user_id, game_id])
}

model System {
  id   String @id @default(cuid())
  name String @unique

  runs            Run[]
  platformSystems PlatformSystem[]
}

model PlatformSystem {
  platform_id String
  system_id   String

  platform Platform @relation(fields: [platform_id], references: [id])
  system   System   @relation(fields: [system_id], references: [id])

  @@id([platform_id, system_id])
}

model Level {
  id          String    @id @default(cuid())
  platform_id String
  name        String
  slug        String
  order       Int       @default(0)
  deleted_at  DateTime?

  platform         Platform        @relation(fields: [platform_id], references: [id])
  level_categories LevelCategory[]
}

model LevelCategory {
  id          String    @id @default(cuid())
  level_id    String
  name        String
  slug        String
  order       Int       @default(0)
  deleted_at  DateTime?

  level     Level      @relation(fields: [level_id], references: [id])
  runs      Run[]
  variables Variable[]
}